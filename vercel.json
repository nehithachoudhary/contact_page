{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/styles\\.css",
      "dest": "public/styles.css"
    },
    {
      "src": "/script\\.js",
      "dest": "public/script.js"
    },
    {
      "src": "/.*",
      "dest": "public/index.html"
    }
  ],
  "env": {
    "PORT": "3000",
